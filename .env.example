# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration (prepare for next step)
DATABASE_URL=postgresql://user:password@localhost:5432/vzw_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vzw_db
DB_USER=vzw_user
DB_PASSWORD=your_secure_password

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Security
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Email (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
